<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>jumps & flies</title>
  <style>
    body {
      margin: 0;
      background: #000000;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    canvas {
      background: linear-gradient(#8492c0, #fdff70);
      border: 5px solid #00f829;
    }
    #restart {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      padding: 10px 20px;
      font-size: 20px;
      background: #000000;
      color: #ff0000;
      border: none;
      display: none;
      cursor: pointer;
    }
    #ui {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: 18px;
      color: rgb(255, 0, 0);
    }
  </style>
</head>
<body>
  <div id="ui">
    Score: <span id="score">0</span><br>
    High Score: <span id="highscore">0</span><br>
    Coins: <span id="coins">0</span>
  </div>
  <button id="restart">Restart</button>
  <canvas id="gameCanvas" width="480" height="720"></canvas>

  <script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const restartBtn = document.getElementById('restart');

    let score = 0, highScore = 0, coins = 0;
    let monkey = { x: 200, y: 600, vy: 0, size: 50 };
    let balloons = [], parrots = [], coinObjects = [];
    let cameraY = 0;
    let gameRunning = true;
    const BASE_LINE = 700;

    function resetGame() {
      monkey = { x: 200, y: 600, vy: 0, size: 50 };
      balloons = [], parrots = [], coinObjects = [];
      score = 0;
      coins = 0;
      cameraY = 0;
      gameRunning = true;
      restartBtn.style.display = 'none';
      for (let i = 0; i < 20; i++) {
        const y = 600 - i * 100;
        balloons.push({ x: Math.random() * 430, y });
        if (Math.random() < 0.3) parrots.push({ x: Math.random() * 430, y });
        if (Math.random() < 0.1) coinObjects.push({ x: Math.random() * 430, y });
      }
    }

    function update() {
      if (!gameRunning) return;
      monkey.vy += 0.6;
      monkey.y += monkey.vy;

      if (monkey.x < 0) monkey.x = 0;
      if (monkey.x + monkey.size > canvas.width) monkey.x = canvas.width - monkey.size;

      if (monkey.y - cameraY > BASE_LINE + 50) {
        gameRunning = false;
        highScore = Math.max(highScore, score);
        restartBtn.style.display = 'block';
        return;
      }

      if (monkey.y + monkey.size > BASE_LINE && monkey.vy > 0 && cameraY <= 0) {
        monkey.vy = -15;
        monkey.y = BASE_LINE - monkey.size;
      }

      balloons.forEach((b, i) => {
        if (
          monkey.y + monkey.size > b.y &&
          monkey.y + monkey.size < b.y + 10 &&
          monkey.x + monkey.size > b.x &&
          monkey.x < b.x + 60 &&
          monkey.vy > 0
        ) {
          monkey.vy = -22;
          balloons.splice(i, 1);
          score++;
        }
      });

      parrots.forEach(p => {
        if (
          monkey.y + monkey.size > p.y &&
          monkey.y < p.y + 30 &&
          monkey.x + monkey.size > p.x &&
          monkey.x < p.x + 50
        ) {
          monkey.vy = -28;
        }
      });

      coinObjects.forEach((c, i) => {
        if (
          monkey.y + monkey.size > c.y &&
          monkey.y < c.y + 30 &&
          monkey.x + monkey.size > c.x &&
          monkey.x < c.x + 30
        ) {
          coinObjects.splice(i, 1);
          coins++;
        }
      });

      if (monkey.y < cameraY + 200) cameraY = monkey.y - 200;

      const minY = Math.min(...balloons.map(b => b.y));
      if (monkey.y - minY < 600) {
        for (let i = 0; i < 10; i++) {
          const y = minY - i * 100;
          balloons.push({ x: Math.random() * 430, y });
          if (Math.random() < 0.3) parrots.push({ x: Math.random() * 430, y });
          if (Math.random() < 0.1) coinObjects.push({ x: Math.random() * 430, y });
        }
      }

      document.getElementById('score').innerText = score;
      document.getElementById('highscore').innerText = highScore;
      document.getElementById('coins').innerText = coins;
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const offsetY = cameraY;

      ctx.fillStyle = '#444';
      ctx.fillRect(0, BASE_LINE - offsetY, canvas.width, 10);

      ctx.fillStyle = '#8B4513';
      ctx.beginPath();
      ctx.arc(monkey.x + 25, monkey.y - offsetY + 25, 25, 0, Math.PI * 2);
      ctx.fill();

      balloons.forEach(b => {
        const colors = ['darkorange', 'red', 'blue', 'purple', 'green', 'hotpink'];
        ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
        ctx.beginPath();
        ctx.arc(b.x + 40, b.y - offsetY + 20, 30, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = 'gold';
        ctx.beginPath();
        ctx.arc(b.x + 40, b.y - offsetY + 20, 15, 0, Math.PI);
        ctx.fill();

        if (coins >= 10) {
          ctx.fillStyle = 'white';
          ctx.font = '20px Arial';
          ctx.fillText('🧸', b.x + 30, b.y - offsetY + 25);
        }
      });

      parrots.forEach(p => {
        ctx.fillStyle = 'deepskyblue';
        ctx.beginPath();
        ctx.moveTo(p.x, p.y - offsetY);
        ctx.lineTo(p.x + 50, p.y - offsetY + 15);
        ctx.lineTo(p.x, p.y - offsetY + 30);
        ctx.closePath();
        ctx.fill();
      });

      coinObjects.forEach(c => {
        ctx.fillStyle = 'gold';
        ctx.beginPath();
        ctx.arc(c.x + 15, c.y - offsetY + 15, 15, 0, Math.PI * 2);
        ctx.fill();
      });

      if (coins >= 5) {
        ctx.fillStyle = '#222';
        ctx.fillText('🎩 New Avatar Unlocked!', 120, 100);
      }
      if (coins >= 10) {
        ctx.fillStyle = '#222';
        ctx.fillText('🧸 Bonus Avatar Unlocked!', 100, 130);
      }
    }

    function gameLoop() {
      update();
      draw();
      requestAnimationFrame(gameLoop);
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') monkey.x = Math.max(0, monkey.x - 30);
      if (e.key === 'ArrowRight') monkey.x = Math.min(canvas.width - monkey.size, monkey.x + 30);
    });

    canvas.addEventListener('click', e => {
      const x = e.clientX - canvas.getBoundingClientRect().left;
      if (x < canvas.width / 2) monkey.x = Math.max(0, monkey.x - 30);
      else monkey.x = Math.min(canvas.width - monkey.size, monkey.x + 30);
    });

    restartBtn.onclick = resetGame;
    resetGame();
    gameLoop();
  </script>
</body>
</html>
